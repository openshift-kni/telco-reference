{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "automergeStrategy": "rebase",
    "automergeType": "pr",
    "prConcurrentLimit": 0,
    "pruneBranchAfterAutomerge": true,
    "packageRules": [
        {
            "addLabels": [
                "allow-automatic-merge"
            ],
            "matchFileNames": [
                "**/rpms.lock.yaml"
            ]
        }
    ],
    "tekton": {
        "addLabels": [
            "allow-automatic-merge"
        ],
        "enabled": true,
        "ignoreTests": false,
        "includePaths": [
            ".tekton/**"
        ],
        "managerFilePatterns": [
            "/\\.yaml$/",
            "/\\.yml$/"
        ]
    }
}
